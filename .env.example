# ---------- Runtime mode ----------
# mock: fully synthetic data, no external calls
# demo: realistic simulated stream, no API keys needed
# live: requires provider keys below
DATA_MODE=demo

# ---------- Database ----------
POSTGRES_USER=fxradar
POSTGRES_PASSWORD=fxradar_dev_change_me
POSTGRES_DB=fxradar
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://fxradar:fxradar_dev_change_me@postgres:5432/fxradar

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---------- API ----------
API_PORT=4000
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:3000
API_JWT_SECRET=change_me_in_production

# ---------- Web ----------
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ---------- Quant engine ----------
QUANT_ENGINE_PORT=5000

# ---------- Live data providers (optional) ----------
CME_API_KEY=
CME_API_SECRET=
